<ul class="post-list">
{%- for post in postslist | reverse %}
  <li class="post-list-item">
    <time class="post-list-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate("yyyy-MM-dd") }}</time>
    <a href="{{ post.url }}" class="post-list-link">{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}</a>
  </li>
{%- endfor %}
</ul>
