---
layout: layouts/home.njk
title: Blog
pagination:
  data: collections.posts
  size: 10
  reverse: true
  alias: paginatedPosts
permalink: "blog/{% if pagination.pageNumber > 0 %}{{ pagination.pageNumber + 1 }}/{% endif %}"
eleventyNavigation:
  key: Blog
  order: 2
---
<h1>Blog</h1>

<ul class="post-list">
{%- for post in paginatedPosts %}
  <li class="post-list-item">
    <time class="post-list-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate("yyyy-MM-dd") }}</time>
    <a href="{{ post.url }}" class="post-list-link">{{ post.data.title }}</a>
  </li>
{%- endfor %}
</ul>

{%- if pagination.pages.length > 1 %}
<nav class="pagination" aria-label="Pagination">
  <div>
    {%- if pagination.href.previous %}
    <a href="{{ pagination.href.previous }}">&larr; Newer</a>
    {%- else %}
    <span>&nbsp;</span>
    {%- endif %}
  </div>
  <span class="pagination-info">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
  <div>
    {%- if pagination.href.next %}
    <a href="{{ pagination.href.next }}">Older &rarr;</a>
    {%- else %}
    <span>&nbsp;</span>
    {%- endif %}
  </div>
</nav>
{%- endif %}
